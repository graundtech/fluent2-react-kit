{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "noEmit": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@graundtech/fluent2-react-kit": ["../../packages/react/src/index.ts"],
      "@kit/*": ["../../packages/react/src/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
